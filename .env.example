# ═══════════════════════════════════════════════════════════
# SMARTPHONE ADDICTION PREDICTION - ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════

# ── Server Configuration ────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database Configuration (Optional) ───────────────────────
# PostgreSQL database for storing predictions and user data
# Leave commented out to run without database
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=smartphone_addiction
# DB_USER=postgres
# DB_PASSWORD=your_password

# ── Email Notifications (Optional but Recommended) ──────────
# Required to send email notifications after predictions
# See NOTIFICATION_SETUP.md for detailed setup instructions

# Gmail Example (FREE):
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASSWORD=your_16_char_app_password
# EMAIL_FROM=your_email@gmail.com

# Outlook Example:
# EMAIL_HOST=smtp-mail.outlook.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@outlook.com
# EMAIL_PASSWORD=your_password
# EMAIL_FROM=your_email@outlook.com

# ── SMS Notifications (Optional - Requires Twilio) ─────────
# Required to send SMS notifications after predictions
# Sign up at: https://www.twilio.com/try-twilio
# Trial account gives $15 free credit (~500 SMS)

# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token_here
# TWILIO_PHONE_NUMBER=+1234567890

# ── Frontend URL ────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── JWT Secret (Optional - For future authentication) ───────
# JWT_SECRET=your_jwt_secret_key_here

# ═══════════════════════════════════════════════════════════
# QUICK START:
# 1. Copy this file to .env
# 2. Uncomment and fill in email credentials (recommended)
# 3. Optionally add Twilio credentials for SMS
# 4. Run: npm start
# 
# See NOTIFICATION_SETUP.md for detailed setup guide
# ═══════════════════════════════════════════════════════════
